{
  "$schema": "https://raw.githubusercontent.com/nicedoc/unpkg/main/@tauri-apps/cli/schema.json",
  "productName": "우당탕탕삼국지",
  "version": "0.1.0",
  "identifier": "com.wdttgukji.app",
  "build": {
    "beforeDevCommand": "npm run dev -- --port 3001",
    "devUrl": "http://localhost:3001",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "우당탕탕삼국지",
        "width": 1600,
        "height": 900,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "minWidth": 800,
        "minHeight": 450
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
